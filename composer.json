{
    "name": "icmbio/validate-xpath-expression",
    "type": "library",
    "scripts": {
        "repl": "php bin/xpath-repl",
        "test": "vendor/bin/phpunit --testdox",
        "test:coverage": "sh tools/test-coverage.sh",
        "stan": "vendor/bin/phpstan analyse --memory-limit=1G --no-progress --debug",
        "check": [
            "@stan",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "8.2.29"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "license": "MIT",
    "bin": [
        "bin/xpath-repl"
    ],
    "autoload": {
        "files": [
            "src/helpers.php"
        ],
        "psr-4": {
            "Icmbio\\ValidateXpathExpression\\": "src/"
        }
    },
    "authors": [
        {
            "name": "João Pedro Garcia",
            "email": "joao.garcia.bolsista@icmbio.gov.br"
        }
    ],
    "require": {},
    "minimum-stability": "stable"
}
